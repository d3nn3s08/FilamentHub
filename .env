# FilamentHub — Umgebungsvariablen
# Kopiere diese Datei zu .env und fülle alle Werte aus.
# NIEMALS die .env Datei in Git committen!
#
# Deutsch: https://github.com/YOUR_USERNAME/FilamentHub/blob/main/ANLEITUNG/
# English: https://github.com/YOUR_USERNAME/FilamentHub/blob/main/ANLEITUNG/README.en.md

# ─────────────────────────────────────────────────────────────
# Admin / Authentifizierung
# ─────────────────────────────────────────────────────────────

# Bcrypt-Hash deines Admin-Passworts.
# Generieren: python -c "import bcrypt; print(bcrypt.hashpw(b'DEIN_PASSWORT', bcrypt.gensalt()).decode())"
ADMIN_PASSWORD_HASH=YOUR_BCRYPT_HASH_HERE

# true = HTTPS-only Cookies (Produktion/Docker). false = auch HTTP (lokale Entwicklung).
ADMIN_COOKIE_SECURE=false

# ─────────────────────────────────────────────────────────────
# App-Metadaten (optional anpassen)
# ─────────────────────────────────────────────────────────────

# Versionsstring der in der UI angezeigt wird
APP_VERSION=Beta v1.6 · FilamentHub

# Design-Versionsstring
DESIGN_VERSION=Design Beta-1.0

# Dev-only Features aktivieren (1 = an, 0 = aus). In Produktion auf 0 lassen!
FILAMENTHUB_DEV_FEATURES=0
